#!/bin/sh /etc/rc.common
# aiqosd - AIQoS main daemon
# Manages all AIQoS sub-modules: sinr_injector, night_lock, condition_detect
# Part of luci-app-aiqos

START=95
STOP=10

USE_PROCD=1
PROG=/usr/bin/sinr_injector.sh

LOG_TAG="aiqosd"
CONFIG_FILE="/etc/config/aiqos"
QUEUE_FIFO="/tmp/uqmi_queue.fifo"
QMODE_PID_FILE="/var/run/qmodem.pid"

log_msg() {
    logger -t "$LOG_TAG" "$1"
}

# Ensure default UCI config exists
ensure_uci() {
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" <<'UCIEOF'
config aiqos 'main'
    option enabled '1'
    option sinr_inject '1'
    option night_lock '0'
    option cake_enabled '1'
    option latency_control '0'
    option gaming_mode '0'
    option auto_detect '1'
    option preset 'office'

config sinr 'settings'
    option interval '2'
    option max_timeouts '5'
    option backoff '15'

config night_lock 'settings'
    option watchdog_interval '30'
    option at_port '/dev/ttyUSB1'
UCIEOF
        log_msg "Created default UCI config"
    fi
}

# Initialize uqmi FIFO queue
init_fifo() {
    [ -p "$QUEUE_FIFO" ] || mkfifo "$QUEUE_FIFO"
}

# Resume qmodem on exit
cleanup_qmodem() {
    local pid=$(cat "$QMODE_PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        if grep -q "T (stopped)" "/proc/$pid/status" 2>/dev/null; then
            kill -CONT "$pid" 2>/dev/null
            sleep 1
            # Health check
            if ! timeout 3 uqmi -d /dev/cdc-wdm0 --get-signal-info >/dev/null 2>&1; then
                log_msg "qmodem health check failed, restarting"
                /etc/init.d/qmodem restart
            fi
        fi
    fi
}

# Run capability detection
run_condition_detect() {
    if [ -x /usr/bin/condition_detect.sh ]; then
        /usr/bin/condition_detect.sh
    fi
}

start_service() {
    ensure_uci
    init_fifo
    run_condition_detect
    
    # Load config
    local enabled=$(uci -q get aiqos.main.enabled || echo 1)
    [ "$enabled" = "0" ] && { log_msg "AIQoS disabled in config"; return 1; }
    
    local sinr_enabled=$(uci -q get aiqos.main.sinr_inject || echo 1)
    local night_enabled=$(uci -q get aiqos.main.night_lock || echo 0)
    
    # Start SINR injector
    if [ "$sinr_enabled" = "1" ]; then
        procd_open_instance
        procd_set_param command /usr/bin/sinr_injector.sh
        procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_close_instance
        log_msg "SINR injector started"
    fi
    
    # Start night_lock if enabled
    if [ "$night_enabled" = "1" ]; then
        procd_open_instance
        procd_set_param command /usr/bin/night_lock.sh
        procd_set_param respawn 3600 5 3
        procd_close_instance
        log_msg "Night lock started"
    fi
    
    log_msg "AIQoS daemon started"
}

stop_service() {
    cleanup_qmodem
    log_msg "AIQoS daemon stopped"
}

service_triggers() {
    procd_add_reload_trigger "aiqos"
}
